# Public Jogg OpenAPI. Override only for an explicit local/mock development server.
JOGG_BASE_URL=https://api.jogg.ai

# Required. Create this in the Jogg OpenAPI dashboard. It remains in process
# memory and is never written to run state or command output.
JOGG_API_KEY=

# Optional stable selections. Otherwise Smart Slides queries available resources.
JOGG_DEFAULT_AVATAR_ID=
JOGG_DEFAULT_VOICE_ID=

# Optional local paths and render controls.
SMART_SLIDES_HOME=~/.codex/smart-slides
SMART_SLIDES_DATA_DIR=~/.codex/smart-slides/data
# Optional private directory containing a verified, platform-matched ffmpeg
# and ffprobe pair. The plugin checks this directory before system PATH.
SMART_SLIDES_TOOL_DIR=~/.codex/smart-slides/bin
# Optional path to a local Chrome/Chromium binary used only to rasterize the
# original Podcastor HTML/MG preview layers before FFmpeg composition.
SMART_SLIDES_CHROME_BIN=
SMART_SLIDES_NODE_BIN=
# Maximum seconds for one Jogg MP4 download attempt before local retry.
SMART_SLIDES_JOGG_DOWNLOAD_MAX_SECONDS=120

# Optional B-roll provider. No other material provider is required by setup.
PEXELS_API_KEY=
